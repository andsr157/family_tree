{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@/*": ["src/*"],
      "@family-tree/schemas": ["../../packages/schemas/dist/index.d.ts"],
      "@family-tree/types": ["../../packages/types/dist/index.d.ts"]
    }
  },
  "include": ["src"]
}
