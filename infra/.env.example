# ─────────────────────────────────────────────────────
# LOCAL DEVELOPMENT — gunakan docker-compose untuk DB/Redis/MinIO
# ZEABUR PRODUCTION — env vars di-inject otomatis via Dashboard
#   DATABASE_URL & REDIS_URL di-link dari managed services
# ─────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://dev:dev@localhost:5432/family_tree

# Redis
REDIS_URL=redis://localhost:6379

# Auth
BETTER_AUTH_SECRET=ganti-dengan-random-string-32-karakter-minimal
# LOCAL: http://localhost:3000
# PRODUCTION: URL service api di Zeabur (beda dengan FRONTEND_URL)
BETTER_AUTH_URL=http://localhost:3000

# File Storage
# Local: MinIO via docker-compose
# Zeabur: tambahkan service "MinIO" dari template → S3_* env ter-link otomatis
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=familytree-media
S3_REGION=us-east-1

# Email
# Local: pakai Mailpit → docker run -p 1025:1025 -p 8025:8025 axllent/mailpit
# Zeabur: gunakan SMTP provider (Resend, SendGrid, dll)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@familytree.app

# App
# LOCAL: http://localhost:5173
# PRODUCTION: https://familytree.dancok.fun
FRONTEND_URL=http://localhost:5173
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
